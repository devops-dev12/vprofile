pipeline {
    agent any

    environment {
        REPO_URL = 'https://github.com/devops-dev12/vprofile.git'
        BRANCH = 'main'
    }

    stages {

        stage('Hello World') {
            steps {
                echo "Hello World from Jenkins Pipeline"
            }
        }

        stage('Clone Repository') {
            steps {
                echo "Cloning vprofile repository..."
                git url: "${REPO_URL}", branch: "${BRANCH}"
            }
        }

        stage('Verify Clone') {
            steps {
                echo "Checking repository contents..."
                sh 'ls -ltr'
            }
        }

        stage('Build Stage') {
            steps {
                echo "Running test build stage..."
                sh 'echo Build Successful'
            }
        }

        stage('Complete') {
            steps {
                echo "Pipeline executed successfully"
            }
        }

    }
}
